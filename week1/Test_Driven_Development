Exercise 4: Arrange-Act-Assert (AAA) Pattern & Fixtures
Task: Write tests using the AAA structure along with lifecycle setup and teardown setups (@BeforeEach/@AfterEach).
CODE:
import org.junit.jupiter.api.AfterEach;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;

public class AAAPatternTest {
    private Calculator calculator;

    @BeforeEach
    public void setUp() {
        // Setup fixture
        calculator = new Calculator();
        System.out.println("Setup: Calculator instance initialized.");
    }

    @Test
    public void testAdditionWithAAAPattern() {
        // 1. Arrange
        int a = 20;
        int b = 30;

        // 2. Act
        int result = calculator.add(a, b);

        // 3. Assert
        assertEquals(50, result);
    }

    @AfterEach
    public void tearDown() {
        // Teardown fixture
        calculator = null;
        System.out.println("Teardown: Resources cleaned up.");
    }
}

