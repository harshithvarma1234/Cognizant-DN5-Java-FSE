Spring Exercise 6: Test Service Exception Handling
Question: Implement code to ensure UserService correctly throws handling errors if records are absent.

Code:
import org.junit.jupiter.api.Test;
import java.util.NoSuchElementException;
import java.util.Optional;
import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.assertThrows;

public class UserServiceExceptionTest {
    @Test
    public void testServiceThrowsExceptionOnMissingUser() {
        UserRepository repo = mock(UserRepository.class);
        // Stubbing repo to return an empty optional structure
        when(repo.findById(99L)).thenReturn(Optional.empty());

        UserService service = new UserService(repo);

        assertThrows(NoSuchElementException.class, () -> {
            // Assuming business logic checks and throws NoSuchElementException when missing
            User user = service.getUserById(99L);
            if (user == null) throw new NoSuchElementException("User not found");
        });
    }
}
