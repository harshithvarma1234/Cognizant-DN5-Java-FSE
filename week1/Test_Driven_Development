Exercise 3: Argument Matching
Scenario:
You need to verify that a method is called with specific arguments.
Steps:
1. Create a mock object.
2. Call the method with specific arguments.
3. Use argument matchers to verify the interaction
Code:
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.assertEquals;

// Shared interfaces for testing
interface ExternalApi { 
    String getData(); 
    String formatData(String input);
    void updateStatus(String status);
}
class MyService {
    private ExternalApi api;
    public MyService(ExternalApi api) { this.api = api; }
    public String processAndFormat(String raw) { return api.formatData(raw); }
}

public class MockitoArgumentMatchingTest {
    @Test
    public void testArgumentMatching() {
        ExternalApi mockApi = mock(ExternalApi.class);
        MyService service = new MyService(mockApi);

        // Stubbing with an argument matcher
        when(mockApi.formatData(anyString())).thenReturn("Matched Output");

        String result = service.processAndFormat("Some Random Input String");
        assertEquals("Matched Output", result);

        // Verifying interaction using argument matchers
        verify(mockApi).formatData(anyString());
    }
}
Exercise 4: Handling Void Methods
Scenario:
You need to test a void method that performs some action.
Steps:
1. Create a mock object.
2. Stub the void method.
3. Verify the interaction.
Code:
import org.junit.jupiter.api.Test;
import static org.mockito.Mockito.*;

class VoidMethodService {
    private ExternalApi api;
    public VoidMethodService(ExternalApi api) { this.api = api; }
    public void executeChange(String status) { api.updateStatus(status); }
}

public class MockitoVoidMethodTest {
    @Test
    public void testVoidMethodInteraction() {
        ExternalApi mockApi = mock(ExternalApi.class);
        VoidMethodService service = new VoidMethodService(mockApi);

        // Stubbing a void method call explicitly (optional as default behavior is nothing)
        doNothing().when(mockApi).updateStatus(anyString());

        service.executeChange("Active");

        // Verify the void method was accurately called with the right argument
        verify(mockApi, times(1)).updateStatus("Active");
    }
}

Exercise 6: Verifying Interaction Order
Question: Write code using Mockito's InOrder API to guarantee that dependencies are executed in a strict chronological sequence.
Code:
import org.junit.jupiter.api.Test;
import org.mockito.InOrder;
import static org.mockito.Mockito.*;

public class MockitoOrderVerificationTest {
    @Test
    public void testVerificationInOrder() {
        ExternalApi mockApi = mock(ExternalApi.class);
        
        // Simulating the sequential operational workflow
        mockApi.getData();
        mockApi.formatData("raw");
        mockApi.updateStatus("Complete");

        // Set up InOrder wrapper verification
        InOrder inOrder = inOrder(mockApi);

        // Verify exact execution sequencing
        inOrder.verify(mockApi).getData();
        inOrder.verify(mockApi).formatData("raw");
        inOrder.verify(mockApi).updateStatus("Complete");
    }
}
Exercise 7: Handling Void Methods with Exceptions
Question: Write code using Mockito's doThrow() strategy to ensure a service properly propagates exceptions when a dependent void method errors out.

Code:
import org.junit.jupiter.api.Test;
import static org.mockito.Mockito.*;
import static org.junit.jupiter.api.Assertions.assertThrows;

public class MockitoVoidExceptionTest {
    @Test
    public void testVoidMethodThrowsException() {
        ExternalApi mockApi = mock(ExternalApi.class);
        VoidMethodService service = new VoidMethodService(mockApi);

        // Stub void method to throw exception when hit
        doThrow(new RuntimeException("Database Offline")).when(mockApi).updateStatus("BadData");

        // Assert system fails gracefully / bubbles up the issue
        assertThrows(RuntimeException.class, () -> {
            service.executeChange("BadData");
        });
    }
}

