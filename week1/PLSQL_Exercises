Scenario 3: Enforce business rules on deposits and withdrawals.
o	Question: Write a trigger CheckTransactionRules that ensures withdrawals do not exceed the balance and deposits are positive before inserting a record into the Transactions table.
. CODE:
CREATE OR REPLACE TRIGGER CheckTransactionRules
BEFORE INSERT ON Transactions
FOR EACH ROW
DECLARE
    v_balance NUMBER;
BEGIN
    -- Make sure they aren't passing zero or negative amounts
    IF :new.Amount <= 0 THEN
        RAISE_APPLICATION_ERROR(-20002, 'Transaction amount has to be positive!');
    END IF;

    -- If trying to withdraw, check if they actually have that much money
    IF :new.TransactionType = 'Withdrawal' THEN
        SELECT Balance INTO v_balance FROM Accounts WHERE AccountID = :new.AccountID;
        IF v_balance < :new.Amount THEN
            RAISE_APPLICATION_ERROR(-20003, 'Transaction rejected: Insufficient funds.');
        END IF;
    END IF;
END;


Exercise 6: Cursors

Scenario 1: Generate monthly statements for all customers.
o	Question: Write a PL/SQL block using an explicit cursor GenerateMonthlyStatements that retrieves all transactions for the current month and prints a statement for each customer.
. CODE:
DECLARE
    CURSOR GenerateMonthlyStatements IS
        SELECT t.TransactionID, t.AccountID, t.TransactionDate, t.Amount, t.TransactionType, a.CustomerID
        FROM Transactions t
        JOIN Accounts a ON t.AccountID = a.AccountID
        WHERE TRUNC(t.TransactionDate, 'MM') = TRUNC(SYSDATE, 'MM');
        
    r_trans GenerateMonthlyStatements%ROWTYPE;
BEGIN
    OPEN GenerateMonthlyStatements;
    LOOP
        FETCH GenerateMonthlyStatements INTO r_trans;
        EXIT WHEN GenerateMonthlyStatements%NOTFOUND;
        
        DBMS_OUTPUT.PUT_LINE('Customer ID: ' || r_trans.CustomerID || 
                             ' | Account: ' || r_trans.AccountID || 
                             ' | Txn ID: ' || r_trans.TransactionID || 
                             ' | Type: ' || r_trans.TransactionType || 
                             ' | Amount: ' || r_trans.Amount);
    END LOOP;
    CLOSE GenerateMonthlyStatements;
END;
