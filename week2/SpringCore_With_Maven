LoggingAspect.java:
Java
package com.library.aspect;
import org.aspectj.lang.JoinPoint;
public class LoggingAspect {
    public void logBefore(JoinPoint joinPoint) {
        System.out.println("[BEFORE ADVICE] Entering method: " + joinPoint.getSignature().getName());
    }
    public void logAfter(JoinPoint joinPoint) {
        System.out.println("[AFTER ADVICE] Finished executing method: " + joinPoint.getSignature().getName());
    }
}

